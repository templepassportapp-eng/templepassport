# Dev secrets — copy to .env.dev on the GCE dev VM, fill in real values.
# NEVER commit .env.dev to version control.

# GCP project ID (same as prod)
GCP_PROJECT_ID=your-gcp-project-id

# Docker image tag — always "dev" for the dev environment
IMAGE_TAG=dev

# PostgreSQL password — can be simpler than prod but still non-trivial
DB_PASSWORD=CHANGE_ME_DEV_PASSWORD

# JWT signing key — must be at least 32 characters, different from prod
JWT_SECRET=CHANGE_ME_DEV_SECRET_32_CHARS_MIN!

# Firebase project ID (same for dev and prod — one Firebase project)
FIREBASE_PROJECT_ID=temple-passport-30183
