# Production secrets — copy to .env.prod on the GCE VM, fill in real values.
# NEVER commit .env.prod to version control.

# GCP project ID (e.g. temple-passport-prod)
GCP_PROJECT_ID=your-gcp-project-id

# Docker image tag — updated automatically by deploy.sh on each deployment
IMAGE_TAG=latest

# PostgreSQL password — use a strong random string (e.g. openssl rand -base64 32)
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT signing key — must be at least 32 characters (maps to jwt.secret in Spring Boot)
JWT_SECRET=CHANGE_ME_MUST_BE_32_CHARS_OR_MORE!
