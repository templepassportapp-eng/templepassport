{
  "expo": {
    "name": "Temple Passport",
    "slug": "temple-passport",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "in.templepassport.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      }
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-image-picker",
        {
          "photosPermission": "Temple Passport needs access to your photos to set a profile picture."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Temple Passport needs your location to verify you are near the temple."
        }
      ],
      "expo-font",
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ]
  }
}
